{
  "name": "@securechat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "prisma": "prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test:e2e": "node scripts/verify-register.mjs && node scripts/verify-auth.mjs && node scripts/verify-messaging.mjs && node scripts/verify-attachments.mjs && node scripts/verify-multidevice.mjs && node scripts/verify-groups.mjs && node scripts/verify-sealed.mjs && node scripts/verify-calls.mjs && node scripts/verify-group-calls.mjs && node scripts/verify-backup.mjs && node scripts/verify-profile.mjs"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "@node-rs/argon2": "^1.8.3",
    "@prisma/client": "^5.19.1",
    "@securechat/crypto": "workspace:*",
    "@securechat/types": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^11.2.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@securechat/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0",
    "typescript": "5.6.3"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# SecureChat environment configuration
# Copy to `.env` and fill in real secrets. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=development
SERVER_PORT=4000
WEB_ORIGIN=http://localhost:5173

# ── PostgreSQL (matches infra/docker-compose.yml) ──
POSTGRES_USER=securechat
POSTGRES_PASSWORD=securechat_dev_password
POSTGRES_DB=securechat
DATABASE_URL=postgresql://securechat:securechat_dev_password@localhost:5432/securechat?schema=public

# ── Redis (presence, typing, cross-instance pub/sub) ──
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ──
# Generate strong values: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace-me-access-secret-min-32-bytes
JWT_REFRESH_SECRET=replace-me-refresh-secret-min-32-bytes
JWT_ACCESS_TTL=900           # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000      # 30 days (seconds)

# ── Object storage (MinIO in dev, S3-compatible in prod) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=securechat-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── Web client (Vite — must be prefixed VITE_) ──
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000/ws
